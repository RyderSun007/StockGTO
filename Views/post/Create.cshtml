@model StockGTO.Models.Post

<h2>📝 新增文章</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">分類</label>
        <input asp-for="Category" class="form-control" placeholder="例如：C# / ABAP / 股票" />
    </div>
    <div class="mb-3">
        <label class="form-label">標題</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">內容</label>
        <textarea asp-for="Content" rows="10" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">發布</button>
</form>
