<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    @* 註解：設定基本頁面資訊與樣式 *@
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StockGTO</title>

    @* 註解：載入 Bootstrap 樣式與圖示 *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    @* 註解：載入專案自訂樣式 *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/StockGTO.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        @* 註解：網站上方導覽列 *@
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @* 註解：網站左上角 LOGO（連結到首頁） *@
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">StockGTO</a>

                @* 註解：手機模式下的摺疊選單按鈕 *@
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @* 註解：首頁連結 *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">🏠 首頁</a>
                        </li>

                        @* 註解：隱私權聲明頁面連結 *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">🔒 隱私</a>
                        </li>

                        @* 註解：顯示員工清單的連結 *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Employee" asp-action="ShowEmployee">👥 員工清單</a>
                        </li>

                        @* 註解：這區塊是布告欄導航連結 *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Post" asp-action="Post">📰 布告欄</a>
                        </li>

                        @* 註解：這區塊是布告欄的管理頁連結 *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Post" asp-action="Manage">🛠 管理文章</a>
                        </li>
                    </ul>

                    @* 註解：顯示登入使用者名稱 *@
                    <p class="nav navbar-text mb-0">Hello, @User.Identity?.Name!</p>
                </div>
            </div>
        </nav>
    </header>

    @* 註解：主內容區塊（每個頁面 View 的內容都會顯示在這） *@
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* 註解：網站頁腳區塊 *@
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - StockGTO - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    @* 註解：JavaScript 套件與自訂 JS 檔案 *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
